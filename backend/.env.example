# Copia este fichero a `backend/.env` y rellena los valores.
# Prisma resuelve los placeholders `${VAR}` en DATABASE_URL gracias a su
# soporte built-in de expansión (equivalente a dotenv-expand).

# Componentes individuales (usados por docker-compose y por DATABASE_URL)
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_PORT=5432

# Cadena de conexión a Postgres
DATABASE_URL="postgresql://${DB_USER}:${DB_PASSWORD}@localhost:${DB_PORT}/${DB_NAME}"

# Puerto en el que escucha la API Express
PORT=3010

# Origen autorizado por CORS para el frontend de desarrollo (CRA)
FRONTEND_ORIGIN=http://localhost:3000
